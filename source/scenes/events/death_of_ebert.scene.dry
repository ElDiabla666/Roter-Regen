[? if jarres_campaign : Jarres - [+ jarres_votes_disp +]% ?]

[? if hergt25_campaign : Hergt - [+ hergt_votes_disp +]% ?]

[? if hindenburg_campaign : Hindenburg - [+ hindenburg_votes_disp +]% ?]

